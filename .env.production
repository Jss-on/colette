# Production environment overrides
# These values override .env when COLETTE_ENVIRONMENT=production
#
# In production, the model_validator in Settings automatically:
#   - Forces debug=False
#   - Clears wildcard CORS origins
#   - Switches checkpoint backend to postgres
#   - Prevents DEBUG log level

COLETTE_ENVIRONMENT=production

# ── LLM ──────────────────────────────────────────────────────────────
# Use the most capable models in production
COLETTE_DEFAULT_PLANNING_MODEL=anthropic/claude-opus-4-6
COLETTE_DEFAULT_EXECUTION_MODEL=anthropic/claude-sonnet-4-6
COLETTE_DEFAULT_VALIDATION_MODEL=anthropic/claude-haiku-4-5

# ── Database ─────────────────────────────────────────────────────────
# COLETTE_DATABASE_URL=  # Set via secret manager or env injection
# COLETTE_REDIS_URL=     # Set via secret manager or env injection

# ── Pipeline ─────────────────────────────────────────────────────────
COLETTE_CHECKPOINT_BACKEND=postgres
COLETTE_MAX_CONCURRENT_PIPELINES=10

# ── Database — connection pool ───────────────────────────────────────
COLETTE_DB_POOL_SIZE=20
COLETTE_DB_MAX_OVERFLOW=30
COLETTE_DB_POOL_TIMEOUT=30
COLETTE_DB_POOL_RECYCLE=1800

# ── Security ─────────────────────────────────────────────────────────
COLETTE_RBAC_ENABLED=true
COLETTE_SECRET_FILTER_ENABLED=true
COLETTE_PROMPT_INJECTION_DEFENSE_ENABLED=true
COLETTE_MCP_ALLOW_UNVERIFIED=false

# ── API ──────────────────────────────────────────────────────────────
COLETTE_CORS_ORIGINS=[]
COLETTE_API_RATE_LIMIT_PER_MINUTE=60

# ── Observability ────────────────────────────────────────────────────
COLETTE_LOG_LEVEL=INFO
COLETTE_LOG_FORMAT=json

# ── Server ───────────────────────────────────────────────────────────
COLETTE_DEBUG=false
COLETTE_WORKERS=4
