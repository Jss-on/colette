# Staging environment overrides
# Mirrors production settings with relaxed limits for testing

COLETTE_ENVIRONMENT=staging

# ── LLM ──────────────────────────────────────────────────────────────
COLETTE_DEFAULT_PLANNING_MODEL=anthropic/claude-sonnet-4-6
COLETTE_DEFAULT_EXECUTION_MODEL=anthropic/claude-sonnet-4-6
COLETTE_DEFAULT_VALIDATION_MODEL=anthropic/claude-haiku-4-5

# ── Pipeline ─────────────────────────────────────────────────────────
COLETTE_CHECKPOINT_BACKEND=postgres
COLETTE_MAX_CONCURRENT_PIPELINES=5

# ── Database — connection pool ───────────────────────────────────────
COLETTE_DB_POOL_SIZE=10
COLETTE_DB_MAX_OVERFLOW=15

# ── Security ─────────────────────────────────────────────────────────
COLETTE_RBAC_ENABLED=true
COLETTE_SECRET_FILTER_ENABLED=true

# ── API ──────────────────────────────────────────────────────────────
COLETTE_CORS_ORIGINS=["https://staging.colette.dev"]
COLETTE_API_RATE_LIMIT_PER_MINUTE=200

# ── Observability ────────────────────────────────────────────────────
COLETTE_LOG_LEVEL=DEBUG
COLETTE_LOG_FORMAT=json

# ── Server ───────────────────────────────────────────────────────────
COLETTE_DEBUG=false
COLETTE_WORKERS=2
