# Colette environment variables
# Copy to .env and fill in real values. Never commit .env to git.
#
# Environment-specific overrides: create .env.development, .env.staging,
# or .env.production alongside this file. Values in .env take precedence.
# See docs/RELEASE.md for environment details.

# ── Environment ──────────────────────────────────────────────────────
# Options: development (default), staging, production, testing
COLETTE_ENVIRONMENT=development

# ── LLM ───────────────────────────────────────────────────────────────
COLETTE_OPENROUTER_API_KEY=
COLETTE_DEFAULT_PLANNING_MODEL=anthropic/claude-sonnet-4-6
COLETTE_DEFAULT_EXECUTION_MODEL=anthropic/claude-sonnet-4-6

# LLM API key (OpenRouter — single key for all providers)
OPENROUTER_API_KEY=

# Provider-specific keys (optional — only needed for direct embeddings)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Fallback chains (empty by default — set only if you have the API keys)
# COLETTE_PLANNING_FALLBACK_MODELS=["gpt-5.4","gemini/gemini-2.5-pro"]
# COLETTE_EXECUTION_FALLBACK_MODELS=["gpt-5.4-mini","gemini/gemini-2.5-flash"]
# COLETTE_VALIDATION_FALLBACK_MODELS=["gpt-5.4-mini","gemini/gemini-2.5-flash"]

# ── Database ──────────────────────────────────────────────────────────
COLETTE_DATABASE_URL=postgresql+asyncpg://colette:colette@localhost:5432/colette
COLETTE_REDIS_URL=redis://localhost:6379/0

# ── Neo4j ─────────────────────────────────────────────────────────────
COLETTE_NEO4J_URI=bolt://localhost:7687
COLETTE_NEO4J_USER=neo4j
COLETTE_NEO4J_PASSWORD=colette-dev

# ── Embeddings (separate from chat — OpenRouter does not serve embeddings)
COLETTE_EMBEDDINGS_API_KEY=
COLETTE_EMBEDDINGS_BASE_URL=https://api.openai.com/v1

# ── Memory ────────────────────────────────────────────────────────
COLETTE_COMPACTION_THRESHOLD=0.70
COLETTE_RAG_CHUNK_SIZE=512
COLETTE_RAG_FAITHFULNESS_THRESHOLD=0.85
COLETTE_KNOWLEDGE_GRAPH_ENABLED=true
COLETTE_COHERE_API_KEY=
COLETTE_COLD_STORAGE_ENDPOINT=
COLETTE_COLD_STORAGE_BUCKET=colette-cold
COLETTE_MEMORY_DECAY_ENABLED=false

# ── Observability ─────────────────────────────────────────────────────
COLETTE_OTEL_SERVICE_NAME=colette
COLETTE_LOG_LEVEL=INFO

# ── Database — connection pool ────────────────────────────────────────
COLETTE_DB_POOL_SIZE=5
COLETTE_DB_MAX_OVERFLOW=10
COLETTE_DB_POOL_TIMEOUT=30
COLETTE_DB_POOL_RECYCLE=3600

# ── Pipeline — checkpointing ─────────────────────────────────────────
COLETTE_CHECKPOINT_BACKEND=memory
# COLETTE_CHECKPOINT_DB_URL=  # Falls back to DATABASE_URL if empty

# ── API ───────────────────────────────────────────────────────────────
COLETTE_API_KEY_HEADER=X-API-Key
COLETTE_API_RATE_LIMIT_PER_MINUTE=100
COLETTE_CORS_ORIGINS=["*"]

# ── GitHub (optional — enables auto-push of generated projects) ──────
COLETTE_GITHUB_TOKEN=
COLETTE_GITHUB_OWNER=
# COLETTE_GITHUB_REPO_PREFIX=colette
# COLETTE_GITHUB_REPO_VISIBILITY=private

# ── Server ────────────────────────────────────────────────────────────
COLETTE_HOST=0.0.0.0
COLETTE_PORT=8000
COLETTE_WORKERS=1
COLETTE_DEBUG=false
