# Colette environment variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── LLM ───────────────────────────────────────────────────────────────
COLETTE_LITELLM_BASE_URL=http://localhost:4000
COLETTE_DEFAULT_PLANNING_MODEL=claude-opus-4-6-20250610
COLETTE_DEFAULT_EXECUTION_MODEL=claude-sonnet-4-6-20250514

# LLM API keys (used by LiteLLM)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Database ──────────────────────────────────────────────────────────
COLETTE_DATABASE_URL=postgresql+asyncpg://colette:colette@localhost:5432/colette
COLETTE_REDIS_URL=redis://localhost:6379/0

# ── Neo4j ─────────────────────────────────────────────────────────────
COLETTE_NEO4J_URI=bolt://localhost:7687
COLETTE_NEO4J_USER=neo4j
COLETTE_NEO4J_PASSWORD=colette-dev

# ── Memory ────────────────────────────────────────────────────────
COLETTE_COMPACTION_THRESHOLD=0.70
COLETTE_RAG_CHUNK_SIZE=512
COLETTE_RAG_FAITHFULNESS_THRESHOLD=0.85
COLETTE_KNOWLEDGE_GRAPH_ENABLED=true
COLETTE_COHERE_API_KEY=
COLETTE_COLD_STORAGE_ENDPOINT=
COLETTE_COLD_STORAGE_BUCKET=colette-cold
COLETTE_MEMORY_DECAY_ENABLED=false

# ── Observability ─────────────────────────────────────────────────────
COLETTE_OTEL_SERVICE_NAME=colette
COLETTE_LOG_LEVEL=INFO

# ── Database — connection pool ────────────────────────────────────────
COLETTE_DB_POOL_SIZE=5
COLETTE_DB_MAX_OVERFLOW=10
COLETTE_DB_POOL_TIMEOUT=30
COLETTE_DB_POOL_RECYCLE=3600

# ── Pipeline — checkpointing ─────────────────────────────────────────
COLETTE_CHECKPOINT_BACKEND=memory
# COLETTE_CHECKPOINT_DB_URL=  # Falls back to DATABASE_URL if empty

# ── API ───────────────────────────────────────────────────────────────
COLETTE_API_KEY_HEADER=X-API-Key
COLETTE_API_RATE_LIMIT_PER_MINUTE=100
COLETTE_CORS_ORIGINS=["*"]

# ── Server ────────────────────────────────────────────────────────────
COLETTE_HOST=0.0.0.0
COLETTE_PORT=8000
COLETTE_WORKERS=1
COLETTE_DEBUG=false
